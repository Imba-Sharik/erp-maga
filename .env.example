# Origin бэка (без /api в конце — пути из OpenAPI уже включают /api/v1/...)
# Прод: https://mag-api.nestforge.com.ru
# Локальный Django: http://localhost:8000
VITE_API_URL=https://mag-api.nestforge.com.ru
VITE_USE_MOCKS=false

# Docker: скопируйте в .env на сервере и пересоберите образ:
#   cp .env.example .env
#   docker compose build --no-cache && docker compose up -d
# VITE_* подставляются при сборке (vite build), не при старте контейнера.

# Dev JWT (локально в .env или .env.local — не коммитить).
# Роли фронта: manager | director | accountant | admin
VITE_DEV_ACCESS_TOKEN_MANAGER=
VITE_DEV_ACCESS_TOKEN_DIRECTOR=
VITE_DEV_ACCESS_TOKEN_ACCOUNTANT=
VITE_DEV_ACCESS_TOKEN_ADMIN=
VITE_DEV_REFRESH_TOKEN_MANAGER=
VITE_DEV_REFRESH_TOKEN_DIRECTOR=
VITE_DEV_REFRESH_TOKEN_ACCOUNTANT=
VITE_DEV_REFRESH_TOKEN_ADMIN=

# Dev-креды для логин-формы (выданы бэком, не коммитить значения).
VITE_DEV_EMAIL_MANAGER=
VITE_DEV_PASSWORD_MANAGER=
VITE_DEV_EMAIL_DIRECTOR=
VITE_DEV_PASSWORD_DIRECTOR=
VITE_DEV_EMAIL_ACCOUNTANT=
VITE_DEV_PASSWORD_ACCOUNTANT=
VITE_DEV_EMAIL_ADMIN=
VITE_DEV_PASSWORD_ADMIN=
