# Базовый URL API для axios (пути из OpenAPI уже включают /api/v1/...).
# Прод (same-origin): оставьте пустым — запросы идут на тот же origin, что и фронт.
# Dev: тоже пустым — Vite проксирует /api на бэкенд (см. VITE_API_PROXY_TARGET).
VITE_API_URL=
VITE_USE_MOCKS=false

# Куда dev-сервер проксирует /api (только vite.config, в клиент не попадает).
# Прод: https://mag-api.nestforge.com.ru
# Локальный Django: http://localhost:8000
VITE_API_PROXY_TARGET=https://mag-api.nestforge.com.ru

# Docker: скопируйте в .env на сервере и пересоберите образ:
#   cp .env.example .env
#   docker compose build --no-cache && docker compose up -d
# VITE_* подставляются при сборке (vite build), не при старте контейнера.

# Dev-креды для логин-формы и переключателя ролей в сайдбаре (не коммитить значения).
# Роли фронта: manager | director | accountant | admin
VITE_DEV_EMAIL_MANAGER=
VITE_DEV_PASSWORD_MANAGER=
VITE_DEV_EMAIL_DIRECTOR=
VITE_DEV_PASSWORD_DIRECTOR=
VITE_DEV_EMAIL_ACCOUNTANT=
VITE_DEV_PASSWORD_ACCOUNTANT=
VITE_DEV_EMAIL_ADMIN=
VITE_DEV_PASSWORD_ADMIN=
